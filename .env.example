# Variables de entorno para el Bot Vectorito
# Copiar este archivo a .env y configurar los valores reales para produccion o desarrollo.

# Configuracion general de IA
# Clave de API principal para Google Gemini. Obtener en aistudio.google.com
GEMINI_API_KEY=
# Clave de API principal para Groq como fallback de respaldo. Obtener en console.groq.com
GROQ_API_KEY=
# Modelo de Gemini a utilizar. Valor por defecto: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Cantidad maxima de turnos de conversacion que el bot recordara por sesion de usuario. Valor por defecto: 12
MAX_CHAT_TURNS=12
# Tiempo de expiracion de la sesion del chat en minutos. Valor por defecto: 120
SESSION_TTL_MINUTES=120

# Modo Feria de Ciencias
# Activa el Modo Feria de Ciencias cuando su valor es true. Suspende filtros restrictivos, eleva cuotas y expande el alcance de las respuestas.
FERIA_MODE=false
# Claves adicionales para Gemini en el Modo Feria. Se usan en orden de prioridad numerica (1, 2, 3...)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# Claves adicionales para Groq en el Modo Feria. Se usan en orden de prioridad numerica (1, 2, 3...)
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Administracion y Seguridad
# Contrasena maestra para acceder al panel web de administracion
ADMIN_PASSWORD=
# Codigos semilla separados por comas para registrar el primer administrador global. Ejemplo: 123456,654321
ADMIN_SEED_CODES=
# Correos electronicos de los superadministradores autorizados a enviar avisos institucionales (separados por comas)
SUPERADMIN_EMAILS=
# Secreto para firmar los tokens JWT de autenticacion del panel web. Cambiar por seguridad
JWT_SECRET=vectorito-secret-key-123456

# Bases de datos
# Ruta al archivo SQLite local. Valor por defecto: data/chatbot.db
SQLITE_PATH=data/chatbot.db
# URL de conexion para la base de datos distribuida en Turso. Ejemplo: libsql://vectorito-vectorito.aws-us-east-1.turso.io
TURSO_DATABASE_URL=
# Token de autenticacion para la conexion a la base de datos de Turso
TURSO_AUTH_TOKEN=

# Servidor de Correo Entrante (IMAP)
# Servidor IMAP legacy de fallback
IMAP_SERVER=imap.gmail.com
# Usuario de correo legacy de fallback
EMAIL_USER=
# Contrasena de correo legacy de fallback
EMAIL_PASS=
# Host del servidor IMAP moderno preferido
IMAP_HOST=imap.gmail.com
# Puerto del servidor IMAP moderno. Valor por defecto: 993
IMAP_PORT=993
# Usuario de correo para el servidor IMAP moderno
IMAP_USER=
# Contrasena de aplicacion de correo para el servidor IMAP moderno
IMAP_PASSWORD=
# Carpeta de correo a sincronizar en IMAP. Valor por defecto: INBOX
IMAP_FOLDER=INBOX
# Indica si se debe rechazar la conexion IMAP ante certificados TLS no validos o auto-firmados
IMAP_TLS_REJECT_UNAUTHORIZED=true
# Ruta al archivo PEM del certificado CA raiz personalizado (opcional)
IMAP_TLS_CA_PATH=
# Nombre del servidor TLS a validar (opcional)
IMAP_TLS_SERVERNAME=

# Servidor de Correo Saliente (SMTP)
# Host del servidor SMTP para el envio de correos
SMTP_HOST=smtp.gmail.com
# Puerto para la conexion SMTP. Valor por defecto: 587
SMTP_PORT=587
# Indica si la conexion SMTP debe ser segura (true para puerto 465, false para 587 o 25)
SMTP_SECURE=false
# Usuario de correo para el servidor SMTP
SMTP_USER=
# Contrasena de aplicacion de correo para el servidor SMTP
SMTP_PASS=
# Direccion de correo electronico remitente para los envios SMTP
SMTP_FROM=

# Limites de Peticiones y Control
# Hora en formato de 24 horas UTC en la que se resetean los limites diarios de IA. Valor por defecto: 0
RATE_LIMIT_RESET_HOUR=0
# Minuto UTC en el que se resetean los limites diarios de IA. Valor por defecto: 0
RATE_LIMIT_RESET_MINUTE=0

# Entorno y Depuracion
# Zona horaria del sistema. Valor por defecto: America/Argentina/Cordoba
TIMEZONE=America/Argentina/Cordoba
# Activa el modo de depuracion general del bot
BOT_DEBUG=false
# Activa la interfaz grafica de terminal (TUI) para visualizacion en consola
TUI_ENABLED=false

# Red y Tunel
# URL base publica del bot para accesos externos y generacion de enlaces de login OTP. Ejemplo: http://localhost:3000 o URL de ngrok
BASE_URL=http://localhost:3000
# Activa la creacion automatica de un tunel local para exponer el bot a internet (ngrok, SSH, localhost.run, etc.)
AUTO_TUNNEL=false
