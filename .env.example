# =============================================================
# Bot Cabezón — Variables de entorno
# Copiar este archivo a .env y completar con valores reales.
# NUNCA subir el .env al repositorio.
# =============================================================

# -------------------------------------------------------------
# 🔑 API Keys (obligatorias)
# -------------------------------------------------------------

# Google Gemini — Obtener en https://aistudio.google.com/
GEMINI_API_KEY=

# Groq — Fallback cuando Gemini falla. Obtener en https://console.groq.com/
GROQ_API_KEY=

# -------------------------------------------------------------
# 🤖 Modelo de IA (opcional, se usa el valor por defecto si se omite)
# -------------------------------------------------------------

# Modelo Gemini a usar. Por defecto: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Máximo de turnos de conversación que el bot recuerda por sesión (por defecto: 12)
MAX_CHAT_TURNS=12

# Duración de la sesión de chat en minutos (por defecto: 120)
SESSION_TTL_MINUTES=120

# -------------------------------------------------------------
# 🔐 Administración
# -------------------------------------------------------------

# Contraseña maestra para acceder al panel de administración
ADMIN_PASSWORD=

# Códigos semilla separados por coma para registrar el primer admin global
# Ejemplo: ADMIN_SEED_CODES=123456,654321
ADMIN_SEED_CODES=

# -------------------------------------------------------------
# 🗄️ Base de datos
# -------------------------------------------------------------

# Ruta al archivo SQLite. Por defecto: data/chatbot.db
SQLITE_PATH=data/chatbot.db

# -------------------------------------------------------------
# 📬 IMAP — Buzón de entrada institucional (avisos por email)
# -------------------------------------------------------------

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Carpeta IMAP a monitorear (por defecto: INBOX)
IMAP_FOLDER=INBOX

# -------------------------------------------------------------
# 📤 SMTP — Correos de confirmación/error salientes (opcional)
# -------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Usar TLS: true | false
SMTP_SECURE=false

SMTP_USER=
SMTP_PASS=

# Dirección "De:" en los correos salientes. Si se omite, se usa SMTP_USER
SMTP_FROM=

# -------------------------------------------------------------
# ⏱️ Rate limiting de IA (opcional)
# -------------------------------------------------------------

# Hora y minuto (UTC) en que se resetean los límites diarios de IA.
# Por defecto: 00:00 UTC
RATE_LIMIT_RESET_HOUR=0
RATE_LIMIT_RESET_MINUTE=0

# -------------------------------------------------------------
# 🌍 Zona horaria
# -------------------------------------------------------------

# Por defecto: America/Argentina/Cordoba
TIMEZONE=America/Argentina/Cordoba

# -------------------------------------------------------------
# ⚙️ Debug
# -------------------------------------------------------------

BOT_DEBUG=false
