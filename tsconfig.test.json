{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "outDir": "./dist-test",
    "rootDir": "./src",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "types": ["vitest", "node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-test"]
}
